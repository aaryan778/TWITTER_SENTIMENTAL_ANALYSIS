# Copy this file, fill in the values, and run:
#   export $(cat .env | xargs)
# OR set each variable manually:
#   export DISCORD_BOT_TOKEN=your_value
#   export GITHUB_TOKEN=your_value

# Discord bot token from discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# GitHub Classic PAT with scopes: repo, project, read:user
GITHUB_TOKEN=your_github_classic_token_here
